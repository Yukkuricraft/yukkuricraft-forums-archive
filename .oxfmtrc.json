{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "printWidth": 120,
  "proseWrap": "always",
  "sortImports": true,
  "overrides": [
    {
      "files": ["*.md", "*.yaml", "*.yml", "*.json"],
      "options": {
        "printWidth": 80
      }
    }
  ]
}
