{
  "name": "@yukkuricraft-forums-archive/backend",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "check-types": "tsc --noEmit",
    "lint": "eslint",
    "fixlint": "eslint --fix"
  },
  "exports": {
    "./*": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@hono/zod-validator": "^0.8.0",
    "@yukkuricraft-forums-archive/database": "workspace:*",
    "@yukkuricraft-forums-archive/frontend": "workspace:*",
    "@yukkuricraft-forums-archive/types": "workspace:*",
    "arctic": "^3.7.0",
    "content-disposition": "^2.0.1",
    "dotenv": "^17.4.2",
    "getenv": "^2.0.0",
    "hono": "^4.12.27",
    "kysely": "^0.29.2",
    "mime-types": "^3.0.2",
    "prisma-extension-kysely": "^4.0.0",
    "unhead": "^3.1.7",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/getenv": "^1.0.3",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^26.1.0",
    "@yukkuricraft-forums-archive/eslint-config": "workspace:*",
    "@yukkuricraft-forums-archive/ts-config": "workspace:*",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  },
  "packageManager": "yarn@4.9.1"
}
