{
  "name": "@yukkuricraft-forums-archive/frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "run-p dev:client dev:server",
    "dev:client": "yarn build-only:client --watch",
    "dev:server": "yarn build-only:server --watch",
    "build": "run-p check-types build-only:client build-only:server",
    "build:client": "run-p check-types build-only:client",
    "build:server": "run-p check-types build-only:server",
    "preview": "vite preview",
    "build-only:client": "vite build --ssrManifest",
    "build-only:server": "vite build --ssr src/entry-server.ts --outDir distserver",
    "check-types": "vue-tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint",
    "fixlint": "eslint --fix"
  },
  "license": "MIT",
